# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"

# MONGODB_URI: A standard MongoDB Atlas connection string to persist
# users, incidents, comments, and threat traces to a durable cloud-hosted database.
# Example: mongodb+srv://username:password@cluster0.abcde.mongodb.net/cybertrace?retryWrites=true&w=majority
MONGODB_URI=

# JWT_SECRET: Secret key used to sign and verify JSON Web Tokens (JWT) for authentication.
# Keep this values highly classified in production.
JWT_SECRET="cybertrace_ossd_secret_key_session_salt"
